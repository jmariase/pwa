{
  "name": "port-io-monorepo-pwa",
  "version": "1.0.0",
  "description": "Monorepo containing PWA frontend client and Express API backend",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run start --workspace=backend",
    "test": "npm test --workspaces --coverage",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0"
  }
}
