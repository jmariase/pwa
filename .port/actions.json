[
  {
    "identifier": "deploy_pwa",
    "title": "Deploy Service to K8s",
    "icon": "Kubernetes",
    "description": "Deploys the PWA client or backend container to a target namespace and replica count in Kubernetes.",
    "trigger": {
      "type": "self-service",
      "operation": "DAY-2",
      "blueprintIdentifier": "microservice",
      "userInputs": {
        "properties": {
          "service": {
            "type": "string",
            "title": "Service to Deploy",
            "description": "Choose which microservice to build and deploy",
            "enum": ["pwa-client-app", "pwa-backend-app"],
            "default": "pwa-client-app"
          },
          "environment": {
            "type": "string",
            "title": "Target Environment",
            "description": "Select stage",
            "enum": ["staging", "production"],
            "default": "staging"
          },
          "namespace": {
            "type": "string",
            "title": "K8s Namespace",
            "description": "Kubernetes Namespace to deploy resources in",
            "default": "default"
          },
          "replicas": {
            "type": "number",
            "title": "Replica Count",
            "description": "Number of pods to boot",
            "default": 2
          }
        },
        "required": ["service", "environment", "namespace", "replicas"]
      }
    },
    "invocationMethod": {
      "type": "GITHUB",
      "org": "YOUR_GITHUB_ORG",
      "repo": "YOUR_GITHUB_REPO",
      "workflow": "deploy.yml",
      "workflowInputs": {
        "service": "{{ .inputs.service }}",
        "environment": "{{ .inputs.environment }}",
        "namespace": "{{ .inputs.namespace }}",
        "replicas": "{{ .inputs.replicas }}",
        "port_run_id": "{{ .run.id }}"
      }
    }
  }
]
