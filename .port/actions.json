[
  {
    "identifier": "deploy_pwa",
    "title": "Deploy PWA Service to K8s",
    "icon": "Kubernetes",
    "description": "Deploys the PWA container to a target namespace and replica count in Kubernetes.",
    "trigger": {
      "type": "self-service",
      "operation": "DAY-2",
      "blueprintIdentifier": "microservice",
      "userInputs": {
        "properties": {
          "environment": {
            "type": "string",
            "title": "Target Environment",
            "description": "Select stage",
            "enum": ["staging", "production"],
            "default": "staging"
          },
          "namespace": {
            "type": "string",
            "title": "K8s Namespace",
            "description": "Kubernetes Namespace to deploy resources in",
            "default": "default"
          },
          "replicas": {
            "type": "number",
            "title": "Replica Count",
            "description": "Number of pods to boot",
            "default": 2
          }
        },
        "required": ["environment", "namespace", "replicas"]
      }
    },
    "invocationMethod": {
      "type": "GITHUB",
      "org": "YOUR_GITHUB_ORG",
      "repo": "YOUR_GITHUB_REPO",
      "workflow": "deploy.yml",
      "workflowInputs": {
        "environment": "{{ .inputs.environment }}",
        "namespace": "{{ .inputs.namespace }}",
        "replicas": "{{ .inputs.replicas }}",
        "port_run_id": "{{ .run.id }}"
      }
    }
  }
]
