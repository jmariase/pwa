[
  {
    "identifier": "microservice",
    "title": "Microservice",
    "icon": "Microservice",
    "schema": {
      "properties": {
        "language": {
          "type": "string",
          "title": "Language",
          "description": "Primary programming language used"
        },
        "framework": {
          "type": "string",
          "title": "Framework",
          "description": "Frontend/Backend framework used"
        },
        "qualityGate": {
          "type": "string",
          "title": "Quality Gate Status",
          "description": "SonarQube Quality Gate Status",
          "enum": ["PASSED", "FAILED", "WARNING", "ERROR"]
        },
        "bugs": {
          "type": "number",
          "title": "Bugs",
          "description": "Number of open bugs reported by SonarQube"
        },
        "vulnerabilities": {
          "type": "number",
          "title": "Vulnerabilities",
          "description": "Number of vulnerabilities reported by SonarQube"
        },
        "coverage": {
          "type": "number",
          "title": "Test Coverage (%)",
          "description": "Code test coverage percentage"
        },
        "repoUrl": {
          "type": "string",
          "format": "url",
          "title": "Repository URL"
        }
      },
      "required": ["language"]
    },
    "relations": {}
  },
  {
    "identifier": "environment",
    "title": "Environment",
    "icon": "Environment",
    "schema": {
      "properties": {
        "type": {
          "type": "string",
          "title": "Environment Type",
          "enum": ["staging", "production", "development"]
        },
        "region": {
          "type": "string",
          "title": "Cloud Region",
          "default": "us-east-1"
        },
        "description": {
          "type": "string",
          "title": "Description"
        }
      },
      "required": ["type"]
    },
    "relations": {}
  },
  {
    "identifier": "deployment",
    "title": "Deployment",
    "icon": "Deployment",
    "schema": {
      "properties": {
        "status": {
          "type": "string",
          "title": "Deployment Status",
          "enum": ["SUCCESS", "FAILURE", "IN_PROGRESS"]
        },
        "version": {
          "type": "string",
          "title": "Deployed Version"
        },
        "namespace": {
          "type": "string",
          "title": "K8s Namespace",
          "description": "Kubernetes namespace used for this deployment"
        },
        "replicas": {
          "type": "number",
          "title": "Replica Count",
          "description": "Number of running pods"
        },
        "imageTag": {
          "type": "string",
          "title": "Docker Image Tag",
          "description": "SHA or version of the Docker container"
        },
        "cluster": {
          "type": "string",
          "title": "K8s Cluster Name",
          "description": "Kubernetes Cluster where the pods reside"
        }
      },
      "required": ["status", "version", "namespace", "replicas", "imageTag"]
    },
    "relations": {
      "microservice": {
        "title": "Microservice",
        "target": "microservice",
        "required": true,
        "many": false
      },
      "environment": {
        "title": "Environment",
        "target": "environment",
        "required": true,
        "many": false
      }
    }
  }
]
